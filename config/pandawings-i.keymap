  &lt 4 ESCAPE       &kp C      &kp S      &kp I             &hm LEFT_SHIFT E   &kp O                                            &kp D           &hm LEFT_SHIFT T   &kp N          &kp R        &kp H   &as DE_SZ
  &kp LEFT_CONTROL   &kp V      &kp X      &kp DE_U_UMLAUT   &kp DE_A_UMLAUT    &kp DE_O_UMLAUT                                  &kp W           &kp G              &as DE_COMMA   &as DE_DOT   &kp K   &kp J
                                                             &to 6              &kp SPACE         &lt 3 DELETE       &lt 2 TAB   &kp BACKSPACE   &as DE_MINUS
            >;
        };

